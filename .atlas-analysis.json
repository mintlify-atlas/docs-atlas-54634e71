  "keyFeatures": [
    "Multi-warehouse support with real-time Firestore synchronization",
    "Role-based access control with 6 distinct user roles",
    "Inbound, storage, and outbound zone management with order queue",
    "Temperature monitoring with automatic alerts for high-temp items",
    "Activity history tracking for ingresos, salidas, and bodega movements",
    "PDF report generation using jsPDF and html2canvas",
    "External warehouse integration (Fridem) via Firebase Realtime Database",
    "CRUD management for buyers (compradores), suppliers (proveedores), and plants (plantas)"
  ],
  "publicApiSurface": [
    "subscribeWarehouseState(warehouseId, handler)",
    "saveWarehouseState(warehouseId, state)",
    "ensureWarehouseState(warehouseId)",
    "subscribeHistoryState(warehouseId, handler)",
    "saveHistoryState(warehouseId, state)",
